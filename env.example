DISCORD_BOT_TOKEN=buraya_discord_bot_tokenini_yapistir
KICK_CLIENT_ID=buraya_kick_client_id
KICK_CLIENT_SECRET=buraya_kick_client_secret
CHECK_INTERVAL_SECONDS=20

# ── ModLog Ayarlari ──
